{
  "manifest_version": 3,

  "name": "Duolingo DuoHacker v2",
  "version": "1.0",
  "description": "Duolingo DuoHacker — Browser Extension",

  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon":  "icon.png",
    "default_title": "DuoHacker"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.duolingo.com/*",
        "https://*.duolingo.cn/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://*.duolingo.com/*",
    "https://*.duolingo.cn/*",
    "https://raw.githubusercontent.com/*",
    "https://avatars.githubusercontent.com/*",
    "https://fonts.googleapis.com/*",
    "https://greasyfork.org/*",
    "https://update.greasyfork.org/*",
    "https://api.twisk.fun/*",
    "https://stories.duolingo.com/*",
    "https://goals-api.duolingo.com/*",
    "https://duolingo-leaderboards-prod.duolingo.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://*.duolingo.com/*",
        "https://*.duolingo.cn/*"
      ]
    }
  ]
}